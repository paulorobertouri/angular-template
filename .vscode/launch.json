{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Angular: Debug App",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "app:run",
      "url": "http://localhost:4200",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Angular: Debug Tests",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "test:watch",
      "url": "http://localhost:9876/debug.html",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Angular: Debug E2E",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["test:e2e:headed"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}"
    }
  ]
}
