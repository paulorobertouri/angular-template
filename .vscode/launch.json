{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Angular: Launch Chrome",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "angular-dev-server",
      "url": "http://localhost:4200/",
      "webRoot": "${workspaceFolder}"
    },
    {
      "name": "Angular: Debug Tests",
      "type": "pwa-chrome",
      "request": "launch",
      "preLaunchTask": "angular-test-server",
      "url": "http://localhost:9876/debug.html",
      "webRoot": "${workspaceFolder}"
    }
  ]
}
